# OSi-plus V7 - Variables de Entorno
# Copia este archivo a .env.local si necesitas configurar variables personalizadas

# Puerto del servidor de desarrollo (opcional)
# Por defecto Vite usa el puerto 5173
# VITE_PORT=5173

# URL base de la aplicación (para producción)
# VITE_BASE_URL=/

# API Endpoints (cuando se integre con backend)
# VITE_API_URL=http://localhost:3000/api
# VITE_API_TIMEOUT=30000

# Configuración de autenticación (futuro)
# VITE_AUTH_DOMAIN=
# VITE_AUTH_CLIENT_ID=

# Ambiente de ejecución
# VITE_ENV=development

# Debug mode
# VITE_DEBUG=false

# =========================================
# NOTA: Variables que empiezan con VITE_ 
# son expuestas al cliente (frontend)
# No incluyas secretos o claves privadas aquí
# =========================================
